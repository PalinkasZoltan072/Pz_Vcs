<UserControl x:Class="CipoBoltAdmin.Views.CipokView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Cipők listája"
                       FontSize="16"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">

                <Button Content="Törlés" MinWidth="100" Height="34" Margin="0,0,10,0" Click="BtnDeleteCipo_Click"/>
                <Button Content="Új cipő" MinWidth="120" Height="34" Margin="0,0,10,0" Click="BtnCreateCipo_Click"/>
                <Button Content="Ár módosítása" MinWidth="140" Height="34" Click="BtnModifyPrice_Click"/>
            </StackPanel>
        </Grid>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Cipok}"
                  SelectedItem="{Binding SelectedCipo}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto">

            <DataGrid.Resources>
                <Style x:Key="TrimmedText" TargetType="TextBlock">
                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                    <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                    <Setter Property="Margin" Value="4,0"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>

                <DataGridTextColumn Header="Név" Binding="{Binding Nev}" Width="2*" ElementStyle="{StaticResource TrimmedText}"/>
                <DataGridTextColumn Header="Márka" Binding="{Binding Marka}" Width="*" ElementStyle="{StaticResource TrimmedText}"/>
                <DataGridTextColumn Header="Méret" Binding="{Binding MeretekText}" Width="*" ElementStyle="{StaticResource TrimmedText}"/>

                <DataGridTextColumn Header="Ár (Ft)" Binding="{Binding Ar}" Width="Auto" MinWidth="80"/>
                <DataGridTextColumn Header="Típus" Binding="{Binding Tipus}" Width="1.5*" ElementStyle="{StaticResource TrimmedText}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>