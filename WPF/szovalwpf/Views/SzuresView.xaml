<UserControl x:Class="CipoBoltAdmin.Views.SzuresView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,12">
            <TextBlock Text="Szűrés"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#111827"
                       VerticalAlignment="Center"
                       DockPanel.Dock="Left"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        DockPanel.Dock="Right">
                <TextBlock Text="Szűrés típusa:"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>

                <ComboBox x:Name="CmbFilterType"
                          Width="180"
                          Height="32"
                          SelectionChanged="CmbFilterType_SelectionChanged">
                    <ComboBoxItem Content="Cipők" IsSelected="True"/>
                    <ComboBoxItem Content="Felhasználók"/>
                    <ComboBoxItem Content="Rendelések"/>
                </ComboBox>
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="240"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10" Padding="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid>
                        <StackPanel x:Name="PanelCipo">
                            <TextBlock Text="Cipő szűrés" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
                            <TextBlock Text="Név"/>
                            <TextBox x:Name="TxtNev" Width="220" Height="30" Margin="0,4,0,10" TextChanged="Filter_TextChanged"/>
                            <TextBlock Text="Márka"/>
                            <TextBox x:Name="TxtMarka" Width="220" Height="30" Margin="0,4,0,10" TextChanged="Filter_TextChanged"/>
                            <TextBlock Text="Méret"/>
                            <WrapPanel x:Name="PanelMeretek" Margin="0,4,0,10">
                                <CheckBox Content="38" Tag="38" Margin="4" Checked="Filter_TextChanged" Unchecked="Filter_TextChanged"/>
                                <CheckBox Content="39" Tag="39" Margin="4" Checked="Filter_TextChanged" Unchecked="Filter_TextChanged"/>
                                <CheckBox Content="40" Tag="40" Margin="4" Checked="Filter_TextChanged" Unchecked="Filter_TextChanged"/>
                                <CheckBox Content="41" Tag="41" Margin="4" Checked="Filter_TextChanged" Unchecked="Filter_TextChanged"/>
                                <CheckBox Content="42" Tag="42" Margin="4" Checked="Filter_TextChanged" Unchecked="Filter_TextChanged"/>
                                <CheckBox Content="43" Tag="43" Margin="4" Checked="Filter_TextChanged" Unchecked="Filter_TextChanged"/>
                                <CheckBox Content="44" Tag="44" Margin="4" Checked="Filter_TextChanged" Unchecked="Filter_TextChanged"/>
                                <CheckBox Content="45" Tag="45" Margin="4" Checked="Filter_TextChanged" Unchecked="Filter_TextChanged"/>
                                <CheckBox Content="46" Tag="46" Margin="4" Checked="Filter_TextChanged" Unchecked="Filter_TextChanged"/>
                            </WrapPanel>
                            <TextBlock Text="Típus"/>
                            <TextBox x:Name="TxtTipus" Width="220" Height="30" Margin="0,4,0,10" TextChanged="Filter_TextChanged"/>
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Min ár"/>
                                    <TextBox x:Name="TxtMinAr" Width="100" Height="30" Margin="0,4,0,0" TextChanged="Filter_TextChanged"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Max ár"/>
                                    <TextBox x:Name="TxtMaxAr" Width="100" Height="30" Margin="0,4,0,0" TextChanged="Filter_TextChanged"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <StackPanel x:Name="PanelFelhasznalo" Visibility="Collapsed">
                            <TextBlock Text="Felhasználó szűrés" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
                            <TextBlock Text="Felhasználónév"/>
                            <TextBox x:Name="TxtFelhasznalonev" Width="220" Height="30" Margin="0,4,0,10" TextChanged="Filter_TextChanged"/>
                            <TextBlock Text="Email"/>
                            <TextBox x:Name="TxtEmail" Width="220" Height="30" Margin="0,4,0,10" TextChanged="Filter_TextChanged"/>
                            <TextBlock Text="Település"/>
                            <TextBox x:Name="TxtTelepules" Width="220" Height="30" Margin="0,4,0,10" TextChanged="Filter_TextChanged"/>
                            <TextBlock Text="Irányítószám"/>
                            <TextBox x:Name="TxtIranyitoszam" Width="220" Height="30" Margin="0,4,0,10" TextChanged="Filter_TextChanged"/>
                        </StackPanel>

                        <StackPanel x:Name="PanelRendeles" Visibility="Collapsed">
                            <TextBlock Text="Rendelés szűrés" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
                            <TextBlock Text="Állapot"/>
                            <TextBox x:Name="TxtAllapot" Width="220" Height="30" Margin="0,4,0,10" TextChanged="Filter_TextChanged"/>
                            <TextBlock Text="Fizetés"/>
                            <TextBox x:Name="TxtFizetes" Width="220" Height="30" Margin="0,4,0,10" TextChanged="Filter_TextChanged"/>
                            <Grid Margin="0,6,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Min mennyiség"/>
                                    <TextBox x:Name="TxtMinMennyiseg" Width="100" Height="30" Margin="0,4,0,0" TextChanged="Filter_TextChanged"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Max mennyiség"/>
                                    <TextBox x:Name="TxtMaxMennyiseg" Width="100" Height="30" Margin="0,4,0,0" TextChanged="Filter_TextChanged"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Cipő ID"/>
                            <TextBox x:Name="TxtCipoId" Width="220" Height="30" Margin="0,4,0,10" TextChanged="Filter_TextChanged"/>
                            <TextBlock Text="Felhasználó ID"/>
                            <TextBox x:Name="TxtFelhasznaloId" Width="220" Height="30" Margin="0,4,0,10" TextChanged="Filter_TextChanged"/>
                        </StackPanel>

                        <Grid VerticalAlignment="Bottom" Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="TxtInfo" Grid.Column="0" Text="Találatok: 0" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Button x:Name="BtnClear" Grid.Column="1" Content="Törlés" Width="120" Height="36" BorderThickness="0" Background="#E5E7EB" Click="BtnClear_Click"/>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Találatok" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,10"/>

                    <DataGrid x:Name="GridCipo" Grid.Row="1" ItemsSource="{Binding TalalatokCipo}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <DataGrid.Resources>
                            <Style x:Key="TrimmedText" TargetType="TextBlock">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                <Setter Property="Margin" Value="4,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                            <DataGridTextColumn Header="Név" Binding="{Binding Nev}" Width="2*" ElementStyle="{StaticResource TrimmedText}"/>
                            <DataGridTextColumn Header="Márka" Binding="{Binding Marka}" Width="*" ElementStyle="{StaticResource TrimmedText}"/>
                            <DataGridTextColumn Header="Méret" Binding="{Binding MeretekText}" Width="*" ElementStyle="{StaticResource TrimmedText}"/>
                            <DataGridTextColumn Header="Ár" Binding="{Binding Ar}" Width="Auto" MinWidth="80"/>
                            <DataGridTextColumn Header="Típus" Binding="{Binding Tipus}" Width="1.5*" ElementStyle="{StaticResource TrimmedText}"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <DataGrid x:Name="GridFelhasznalo" Grid.Row="1" Visibility="Collapsed" ItemsSource="{Binding TalalatokFelhasznalo}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <DataGrid.Resources>
                            <Style x:Key="TrimmedText" TargetType="TextBlock">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                <Setter Property="Margin" Value="4,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                            <DataGridTextColumn Header="Felhasználónév" Binding="{Binding Felhasznalonev}" Width="1.5*" ElementStyle="{StaticResource TrimmedText}"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="2.5*" ElementStyle="{StaticResource TrimmedText}"/>
                            <DataGridTextColumn Header="Település" Binding="{Binding Telepules}" Width="*" ElementStyle="{StaticResource TrimmedText}"/>
                            <DataGridTextColumn Header="Irányítószám" Binding="{Binding Iranyitoszam}" Width="Auto" MinWidth="90"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <DataGrid x:Name="GridRendeles" Grid.Row="1" Visibility="Collapsed" ItemsSource="{Binding TalalatokRendeles}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <DataGrid.Resources>
                            <Style x:Key="TrimmedText" TargetType="TextBlock">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                <Setter Property="Margin" Value="4,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                            <DataGridTextColumn Header="Állapot" Binding="{Binding Allapot}" Width="1.5*" ElementStyle="{StaticResource TrimmedText}"/>
                            <DataGridTextColumn Header="Fizetés" Binding="{Binding Fizetes}" Width="*" ElementStyle="{StaticResource TrimmedText}"/>
                            <DataGridTextColumn Header="Mennyiség" Binding="{Binding Mennyiseg}" Width="Auto" MinWidth="80"/>
                            <DataGridTextColumn Header="Méret" Binding="{Binding Meret}" Width="Auto" MinWidth="60"/>
                            <DataGridTextColumn Header="Cipő ID" Binding="{Binding Cipo_id}" Width="Auto" MinWidth="70"/>
                            <DataGridTextColumn Header="Felh. ID" Binding="{Binding Felhasznalo_id}" Width="Auto" MinWidth="70"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>