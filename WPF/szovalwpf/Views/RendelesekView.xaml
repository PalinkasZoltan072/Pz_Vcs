<UserControl x:Class="CipoBoltAdmin.Views.RendelesekView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Rendelések listája"
                       FontSize="16"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">

                <Button Content="Törlés" MinWidth="100" Height="34" Margin="0,0,10,0" Click="BtnDeleteOrder_Click"/>
                <Button Content="Állapot módosítás" MinWidth="160" Height="34" Click="BtnModifyStatus_Click"/>
            </StackPanel>
        </Grid>

        <DataGrid x:Name="DgRendelesek"
                  Grid.Row="1"
                  ItemsSource="{Binding Rendelesek}"
                  SelectedItem="{Binding SelectedRendeles}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto">

            <DataGrid.Resources>
                <Style x:Key="TrimmedText" TargetType="TextBlock">
                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                    <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                    <Setter Property="Margin" Value="4,0"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                <DataGridTextColumn Header="Felh. ID" Binding="{Binding Felhasznalo_id}" Width="Auto" MinWidth="70"/>
                <DataGridTextColumn Header="Cipő ID" Binding="{Binding Cipo_id}" Width="Auto" MinWidth="70"/>

                <DataGridTextColumn Header="Méret" Binding="{Binding Meret}" Width="Auto" MinWidth="60"/>
                <DataGridTextColumn Header="Mennyiség" Binding="{Binding Mennyiseg}" Width="Auto" MinWidth="80"/>

                <DataGridTextColumn Header="Fizetés" Binding="{Binding Fizetes}" Width="*" ElementStyle="{StaticResource TrimmedText}"/>
                <DataGridTextColumn Header="Állapot" Binding="{Binding Allapot}" Width="1.5*" ElementStyle="{StaticResource TrimmedText}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>