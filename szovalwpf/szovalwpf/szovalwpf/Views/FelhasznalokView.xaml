<UserControl x:Class="CipoBoltAdmin.Views.FelhasznalokView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- FELSŐ SÁV -->
        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Felhasználók listája"
               FontSize="16"
               FontWeight="SemiBold"
               Foreground="#111827"
               VerticalAlignment="Center"
               DockPanel.Dock="Left"/>

            <!-- JOBB: gombok -->
            <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Right"
                DockPanel.Dock="Right">

                <Button Content="Törlés"
                Width="100"
                Height="34"
                Margin="0,0,10,0"
                Click="BtnDeleteUser_Click"/>

                <Button Content="Módosítás"
                Width="120"
                Height="34"
                Margin="0,0,10,0"
                Click="BtnModifyUser_Click"/>
            </StackPanel>
        </DockPanel>

        <!-- TÁBLÁZAT -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Felhasznalok}"
                  SelectedItem="{Binding SelectedFelhasznalo, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
                <DataGridTextColumn Header="Felhasználónév" Binding="{Binding Felhasznalonev}" Width="180"/>
                <DataGridTextColumn Header="Jelszó" Binding="{Binding Jelszo}" Width="180"/>

                <DataGridTextColumn Header="Település" Binding="{Binding Telepules}" Width="160"/>
                <DataGridTextColumn Header="Irányítószám" Binding="{Binding Iranyitoszam}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
