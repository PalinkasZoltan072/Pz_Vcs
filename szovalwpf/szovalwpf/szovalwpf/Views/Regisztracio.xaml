<Window x:Class="CipoBoltAdmin.Regisztracio"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin regisztráció" Height="420" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Új admin regisztráció"
                   FontSize="18" FontWeight="SemiBold"
                   Margin="0,0,0,15"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Felhasználónév"/>
            <TextBox x:Name="TxtUser" Height="28"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Email"/>
            <TextBox x:Name="TxtEmail" Height="28"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="Jelszó"/>
            <PasswordBox x:Name="TxtPass1" Height="28"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="0,0,0,10">
            <TextBlock Text="Jelszó még egyszer"/>
            <PasswordBox x:Name="TxtPass2" Height="28"/>
        </StackPanel>

        <StackPanel Grid.Row="5">
            <Button Content="Regisztráció" Height="34" Click="BtnRegister_Click"/>

            <TextBlock Margin="0,12,0,0" HorizontalAlignment="Center">
                <Hyperlink Click="GoLogin_Click">Már van fiókom</Hyperlink>
            </TextBlock>
        </StackPanel>
    </Grid>
</Window>
