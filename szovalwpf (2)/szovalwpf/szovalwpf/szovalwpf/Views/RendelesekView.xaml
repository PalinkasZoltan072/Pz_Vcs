<UserControl x:Class="CipoBoltAdmin.Views.RendelesekView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,12">

            <!-- BAL: cím -->
            <TextBlock Text="Rendelések listája"
               FontSize="16"
               FontWeight="SemiBold"
               Foreground="#111827"
               VerticalAlignment="Center"
               DockPanel.Dock="Left"/>

            <!-- JOBB: gombok -->
            <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Right"
                DockPanel.Dock="Right">

                <Button Content="Törlés"
                Width="100"
                Height="34"
                Margin="0,0,10,0"
                Click="BtnDeleteOrder_Click"/>

                <Button Content="Állapot módosítása"
                Width="160"
                Height="34"
                Margin="0,0,10,0"
                Click="BtnModifyStatus_Click"/>

                

            </StackPanel>

        </DockPanel>


        <DataGrid x:Name="DgRendelesek"
          Grid.Row="1"
          ItemsSource="{Binding Rendelesek}"
          SelectedItem="{Binding SelectedRendeles, Mode=TwoWay}"
          SelectionMode="Single"
          SelectionUnit="FullRow"
          AutoGenerateColumns="False"
          IsReadOnly="True"
          CanUserAddRows="False"
          RowHeight="34">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                <DataGridTextColumn Header="Felhasználó ID" Binding="{Binding Felhasznalo_id}" Width="140"/>
                <DataGridTextColumn Header="Cipő ID" Binding="{Binding Cipo_id}" Width="100"/>
                <DataGridTextColumn Header="Mennyiség" Binding="{Binding Mennyiseg}" Width="110"/>
                <DataGridTextColumn Header="Fizetés" Binding="{Binding Fizetes}" Width="140"/>
                <DataGridTextColumn Header="Állapot" Binding="{Binding Allapot}" Width="160"/>
            </DataGrid.Columns>

        </DataGrid>

    </Grid>
</UserControl>
