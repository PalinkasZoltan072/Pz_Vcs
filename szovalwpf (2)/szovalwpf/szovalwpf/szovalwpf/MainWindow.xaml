<Window x:Class="CipoBoltAdmin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CipőBolt - Admin" Height="650" Width="1050"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6FA">

    <!-- ERŐSEN FONTOS: a stílus legyen FELÜL, mielőtt használod -->
    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,0,0,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1F2937"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- BAL OLDAL: Sidebar -->
        <Border Grid.Column="0" Background="#111827" Padding="16">
            <DockPanel LastChildFill="True">

                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                    <TextBlock Text="CipőBolt" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="Admin Panel" FontSize="12" Foreground="#9CA3AF" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Top">
                    <Button Content="Dashboard" Click="BtnDashboard_Click" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Cipők" Click="BtnCipok_Click" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Felhasználók" Click="BtnFelhasznalok_Click" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Rendelések" Click="BtnRendelesek_Click" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Szűrés" Click="BtnSzures_Click" Style="{StaticResource MenuButtonStyle}"/>
                </StackPanel>

                <Button DockPanel.Dock="Bottom"
                        Content="Kijelentkezés"
                        Click="BtnLogout_Click"
                        Background="#374151"
                        Foreground="White"
                        BorderThickness="0"
                        Height="40"
                        Margin="0,16,0,0"/>
            </DockPanel>
        </Border>

        <!-- JOBB OLDAL: Tartalom -->
        <Grid Grid.Column="1" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="White" CornerRadius="10" Padding="16">
                <TextBlock x:Name="TxtPageTitle"
                           Text="Dashboard"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#111827"/>
            </Border>

            <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="16" Margin="0,12,0,0">
                <ContentControl x:Name="MainContent"/> 
            </Border>
        </Grid>
    </Grid>
</Window>
